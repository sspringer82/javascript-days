generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
}

model Book {
  id            Int      @id @default(autoincrement())
  title         String
  isbn          String   @unique
  author        String
  publishedYear Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}
